C4Container
    title Container Diagram for Agentic.nvim - AI Assistant Integration Plugin

    System_Boundary(providers, "External Providers") {
        Container(copilot_cli, "Copilot CLI", "CLI for GitHub Copilot", "Github Copilot Provider")
        Container(opencode_cli, "OpenCode CLI", "CLI for OpenCode AI", "OpenCode AI Provider")
        Container(gemini_cli, "Gemini CLI", "CLI for Google Gemini", "Google Gemini Provider")
    }

    System_Boundary(neovim, "Neovim Editor + other plugins") {
        Container(treesitter, "nvim-treesitter", "Lua plugin", "Provides syntax tree parsing and code analysis (planned integration)")
        Container(gitsigns, "Gitsigns", "Lua plugin", "Offers Git integration for tracking changes (planned integration)")
        Container(blink_cmp, "Blink.cmp", "Rust/Lua", "Autocompletion engine providing inline code suggestions")
        Container(copilot_lsp, "Copilot LSP", "Lua", "Language server integration for Next Edit Suggestions (NES)")
        Container(plenary, "Plenary.nvim", "Lua", "Utility library for async operations and common functions")
    }

    System_Boundary(plugin, "Agentic Plugin Environment") {
        Container(agentic_plugin, "Agentic Plugin", "Lua", "Orchestrates AI assistant integration, manages UI, state, and terminal processes")
        Container(term_ui, "Terminal UI Window", "Neovim Buffer/Terminal", "Interactive terminal interface displaying AI CLI sessions with custom statusline")
        Container(state_mgr, "State Manager", "Lua Singleton", "Manages runtime state: buffers, windows, terminal job IDs, provider metadata")
        Container(config_sys, "Configuration System", "Lua", "Stores provider settings and window layout configuration")
        Container(event_handler, "Event Handler System", "Lua Autocmds", "Manages plugin lifecycle: buffer/window events, terminal cleanup, resize handling")
    }

    Person(developer, "Neovim User", "Developer using Neovim editor who interacts with AI assistants for code assistance")

    Rel(developer, agentic_plugin, "Executes commands", "AgenticToggle, AgenticProvider")
    Rel(developer, term_ui, "Interacts with AI", "Terminal input/output")
    
    Rel(agentic_plugin, term_ui, "Creates & manages", "vim.api buffers/windows")
    Rel(agentic_plugin, state_mgr, "Reads/updates state", "Singleton access")
    Rel(agentic_plugin, config_sys, "Reads configuration", "Provider settings, UI layout")
    Rel(agentic_plugin, event_handler, "Registers autocmds", "BufWinEnter, VimResized, etc.")
    
    Rel(agentic_plugin, copilot_cli, "Spawns process", "vim.fn.jobstart()")
    Rel(agentic_plugin, opencode_cli, "Spawns process", "vim.fn.jobstart()")
    Rel(agentic_plugin, gemini_cli, "Spawns process", "vim.fn.jobstart()")
    
    Rel(term_ui, copilot_cli, "Displays output from", "Terminal stdout/stderr")
    Rel(term_ui, opencode_cli, "Displays output from", "Terminal stdout/stderr")
    Rel(term_ui, gemini_cli, "Displays output from", "Terminal stdout/stderr")
    
    Rel(agentic_plugin, blink_cmp, "Configures sources", "Copilot provider integration")
    Rel(agentic_plugin, copilot_lsp, "Configures keymaps", "NES acceptance bindings")
    Rel(agentic_plugin, plenary, "Uses utilities", "Async helpers")
    
    Rel(blink_cmp, copilot_lsp, "Requests completions", "LSP protocol")
    Rel(blink_cmp, developer, "Shows suggestions", "Inline ghost text")
    
    Rel(state_mgr, term_ui, "Tracks buffer/window IDs", "Runtime state")
    Rel(event_handler, state_mgr, "Updates on events", "Visibility, cleanup")
    
    Rel(agentic_plugin, treesitter, "Will use for context", "Scope extraction (planned)")
    Rel(agentic_plugin, gitsigns, "Will use for changes", "Diff management (planned)")

    UpdateRelStyle(developer, agentic_plugin, $offsetY="20", $offsetX="10")
    UpdateRelStyle(agentic_plugin, treesitter, $offsetY="20", $offsetX="-120")
    UpdateRelStyle(agentic_plugin, gitsigns, $offsetY="30", $offsetX="-80")
    
    UpdateLayoutConfig($c4ShapeInRow="3", $c4BoundaryInRow="2")