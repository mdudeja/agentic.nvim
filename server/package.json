{
  "name": "server",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run --env-file .env index.ts",
    "start:http": "bun run --env-file .env.http index.ts --watch",
    "lint": "bun tsc --noEmit",
    "build": "bun run gen:openrpc && bun build index.ts --minify",
    "test": "bun test",
    "gen:openrpc": "bun run scripts/gen-openrpc.ts"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.14.1",
    "@paralleldrive/cuid2": "^3.3.0",
    "drizzle-orm": "^1.0.0-beta.15-859cf75",
    "temporal-polyfill": "^0.3.0",
    "typebox": "^1.1.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "drizzle-kit": "^1.0.0-beta.15-859cf75"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
